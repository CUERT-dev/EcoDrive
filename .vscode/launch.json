{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [

          {
            "name": "BMP launch",
            "cwd": "${workspaceRoot}",
            "executable": "${workspaceRoot}/build/bin/EcoDrive.elf",
            "armToolchainPath": "/usr/bin",
            "gdbPath": "/opt/gcc-arm-none-eabi-10.3/bin/arm-none-eabi-gdb",
            "BMPGDBSerialPort": "/dev/ttyBmpGdb",
            "showDevDebugOutput": "raw",
            "request": "launch",    // "launch" also works perhaps
            "type": "cortex-debug",
            "servertype": "bmp",
            "interface": "swd",
            "device": "STM32FF401",
        }
    ]
}